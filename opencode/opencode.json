{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "ollama/qwen3.5:0.8b",
  "permission": {
    "bash": "ask",
    "edit": "allow",
    "question": "allow",
    "read": "allow",
    "todowrite": "allow",
    "websearch": "allow"
  },
  "plugin": ["@tarquinen/opencode-dcp@latest", "@plannotator/opencode@latest"],
  "agent": {
    "plan": {
      "model": "google/gemini-3.1-flash-lite-preview",
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "build": {
      "model": "ollama/qwen3-coder:30b",
      "temperature": 0,
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    }
  },
  "watcher": {
    "ignore": ["browser/node_modules/**", "dist/**", ".git/**", ".svelte-kit/**", "build/**"]
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "${LITELLM_MASTER_KEY}"
      },
      "models": {
        "gemini-2.0-flash": {
          "name": "Gemini 2.0 Flash",
          "limit": {
            "context": 1048576,
            "output": 8192
          }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 2097152,
            "output": 8192
          }
        }
      }
    },
    "ollama": {
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3.5:0.8b": {
          "name": "qwen3.5:0.8b",
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },
        "qwen3.5:9b": {
          "name": "qwen3.5:9b",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "qdrant": {
      "type": "local",
      "command": ["uvx", "mcp-server-qdrant"],
      "environment": {
        "QDRANT_LOCAL_PATH": "${workspaceFolder}/.qdrant_storage",
        "COLLECTION_NAME": "project-context"
      },
      "enabled": false
    },
    "MCP_DOCKER": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
